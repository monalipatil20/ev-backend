# Backend - Environment Variables Example
# Copy this file to backend/.env.local for local development
# Copy this file to backend/.env.production for production deployment

# Server Configuration
NODE_ENV=development
PORT=5001

# Database Configuration
# Local MongoDB: mongodb://localhost:27017/energeia-dev
# MongoDB Atlas: mongodb+srv://username:password@your-cluster.mongodb.net/energeia-prod
MONGODB_URI=mongodb://localhost:27017/energeia-dev
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=2

# CORS Configuration
# Comma-separated list of allowed origins
# For development: http://localhost:3000,http://localhost:19006,exp://localhost
# For production: https://your-frontend-url.vercel.app,https://yourdomain.com
CORS_ORIGIN=http://localhost:3000,http://localhost:19006,http://localhost:19007,http://127.0.0.1:19006,exp://localhost:8081

# API Configuration
API_PREFIX=/api

# JWT Configuration
# Generate secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d
JWT_REFRESH_EXPIRATION=30d

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@energeia.com

# Stripe Configuration (optional)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags
ENABLE_DEBUG_LOGS=true
ENABLE_MOCK_DATA=false

# Environment Type
ENV=development
